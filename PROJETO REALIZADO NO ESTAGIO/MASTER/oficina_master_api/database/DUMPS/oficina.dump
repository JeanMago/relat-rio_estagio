  `updated_at` timestamp NULL DEFAULT NULL,
  PRIMARY KEY (`id`),
  UNIQUE KEY `ibpt_versoes_versao_unique` (`versao`),
  KEY `ibpt_versoes_ativa_publicada_em_index` (`ativa`,`publicada_em`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;
