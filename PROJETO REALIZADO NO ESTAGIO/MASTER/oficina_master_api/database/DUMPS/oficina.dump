DROP TABLE IF EXISTS `ibpt_itens`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!50503 SET character_set_client = utf8mb4 */;
CREATE TABLE `ibpt_itens` (
  `id` bigint unsigned NOT NULL AUTO_INCREMENT,
  `ibpt_versao_id` bigint unsigned NOT NULL,
  `uf` varchar(2) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `ncm` varchar(8) COLLATE utf8mb4_unicode_ci NOT NULL,
  `ex_tipi` varchar(3) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `descricao` varchar(255) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `aliquota_federal_nacional` decimal(8,4) NOT NULL DEFAULT '0.0000',
  `aliquota_federal_importado` decimal(8,4) NOT NULL DEFAULT '0.0000',
  `aliquota_estadual` decimal(8,4) NOT NULL DEFAULT '0.0000',
  `aliquota_municipal` decimal(8,4) NOT NULL DEFAULT '0.0000',
  `chave` varchar(80) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `fonte` varchar(60) COLLATE utf8mb4_unicode_ci NOT NULL DEFAULT 'IBPT',
  `created_at` timestamp NULL DEFAULT NULL,
  `updated_at` timestamp NULL DEFAULT NULL,
  PRIMARY KEY (`id`),
  UNIQUE KEY `uq_ibpt_item_versao_ncm_ex_uf` (`ibpt_versao_id`,`ncm`,`ex_tipi`,`uf`),
  KEY `ibpt_itens_ibpt_versao_id_ncm_uf_index` (`ibpt_versao_id`,`ncm`,`uf`),
  CONSTRAINT `ibpt_itens_ibpt_versao_id_foreign` FOREIGN KEY (`ibpt_versao_id`) REFERENCES `ibpt_versoes` (`id`) ON DELETE CASCADE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;
